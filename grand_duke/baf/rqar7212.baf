        CreateCreature("rqfisth1",[2250.391],S)
        CreateCreature("rqfisth1",[419.1582],NE)
        CreateCreature("rqfisth1",[428.1659],NE)
        CreateCreature("rqfisth1",[433.1619],NE)
        CreateCreature("rqfisth1",[2082.1608],NW)
        CreateCreature("rqfisth1",[2228.1581],NW)
        CreateCreature("rqfisth1",[2190.1582],NW)
