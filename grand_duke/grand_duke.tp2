// Brokkr Dwarf Fighter/Thief ----- add NPC dialog references -----
APPEND ~pdialog.2da~ // SOA append
~rqbro           rqbroP               rqbroJ              rqbroD~
UNLESS ~rqbro~ // somehow we are already there, skip it
UNLESS ~25POST~ // means TOB is installed, skip it

APPEND ~pdialog.2da~ // TOB append
~rqbro         rqbroP               rqbroJ             rqbro25D         rqbro25P           rqbro25J           rqbro25D             rqbro25~
UNLESS ~rqbro~ // we are already there, skip it
IF     ~25POST~ // requires TOB to be installed

APPEND ~interdia.2da~ // SOA append
~rqbro         Brqbro~
UNLESS ~rqbro~ // somehow we are already there, skip it
UNLESS ~25POST~ // means TOB is installed, skip it

APPEND ~interdia.2da~ // TOB append
~rqbro         Brqbro          Brqbro25~
UNLESS ~rqbro~ // we are already there, skip it
IF     ~25POST~ // requires TOB to be installed

// Elf Rhiviq Mage Diviner
COPY ~grand_duke/cre/rqrhiv.cre~ ~override/rqrhiv.cre~
  SAY NAME1 ~Rhiviq~
  SAY NAME2 ~Rhiviq~
  SAY BIO ~I am an orphan. I have no name, no family, nothing. How much more do you want to know, and how much more is there to tell about oneself?~
SAY TIRED ~*Yawn* We should rest now; my mind grows weary.~
SAY HURT ~My wounds are grave; help me!~
SAY TARGET_IMMUNE ~Magic would be preferred here.~
SAY INVENTORY_FULL ~My word, I cannot cope with all this stuff. I have dropped your item.~
SAY SPELL_DISRUPTED ~I failed to foresee this magical failure.~
SAY SET_A_TRAP ~Trap have I set.~

// Elf Rhiviq Mage Diviner ----- add NPC dialog references -----
APPEND ~pdialog.2da~ // SOA append
~rqrhiv         rqrhivP               rqrhivJ              rqrhivD~
UNLESS ~rqrhiv~ // somehow we are already there, skip it
UNLESS ~25POST~ // means TOB is installed, skip it

APPEND ~pdialog.2da~ // TOB append
~rqrhiv         rqrhivP               rqrhivJ             rqrhiv25D         rqrhiv25P           rqrhiv25J           rqrhiv25D             rqrhiv25~
UNLESS ~rqrhiv~ // we are already there, skip it
IF     ~25POST~ // requires TOB to be installed

APPEND ~interdia.2da~ // SOA append
~rqrhiv         Brqrhiv~
UNLESS ~rqrhiv~ // somehow we are already there, skip it
UNLESS ~25POST~ // means TOB is installed, skip it

APPEND ~interdia.2da~ // TOB append
~rqrhiv         Brqrhiv          Brqrhiv25~
UNLESS ~rqrhiv~ // we are already there, skip it
IF     ~25POST~ // requires TOB to be installed

