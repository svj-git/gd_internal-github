BACKUP ~grand_duke/backup~
AUTHOR ~oaq@gmx.com~

VERSION ~v1.0i~

README ~grand_duke/grand_duke-readme.txt~

BEGIN ~Grand Duke of Baldur's Gate mod (Requires Baldurs Gate Trilogy mod)~
LABEL ~Grand_Duke_of_Baldur's Gate~
REQUIRE_PREDICATE ((GAME_IS ~bgt~) OR (MOD_IS_INSTALLED ~BGT/BGT.TP2~ "0")) ~This mod requires Baldurs Gate Trilogy mod installed~


/* Compile everything in D directory to DLG in override D >> override/DLG */
COMPILE ~grand_duke/d~

/* Copy sounds */
COPY ~grand_duke/sounds/rqsink.wav~ ~override/rqsink.wav~

/* Create new talking items */
COPY_EXISTING ~itemdial.2da~ ~override~

APPEND ~itemdial.2da~
~rqcrat01   9460   rqcrat01~
UNLESS ~rqcrat01~

APPEND ~itemdial.2da~
~rqbook2    4978  rqbook2~
UNLESS ~rqbook2~

// Epilogue stuff
COPY ~grand_duke/2da/rqbro.2da~ ~override/rqbro.2da~
  REPLACE ~99999~ ~Brokkr after adventuring with <CHARNAME> disappeared from Faerun for some time nobody knew where he was and what he did but emerged in Thar as leader of warband which were raiding the caravans supplying city of Glister. Town tried to defeat Brokkr but failed every time but then Brokkr did something unexpected he requested to negotiate with Glisters leadership. If leaders of Glister would made him into captain of Glister he would protect the town and he had the army which could do it. Glister leadership have accepted for they had no choice and as of writing this epilogue all that is known is that Brokkr is now one of most powerful men in Glister.~
EXTEND_TOP ~ar6200.bcs~ ~grand_duke/baf/rqar6200.baf~

