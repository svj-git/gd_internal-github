// Undercellar
IF
    Global("rqGDNeutralPathStep4","GLOBAL",1)
    Global("rqGDLezgynSpawn","AR7212",0) // Undercellar
THEN
    RESPONSE #100
        SetGlobal("rqGDLezgynSpawn","AR7212",1) // Undercellar
        CreateCreature("rqcofist",[1488.892],0) // Lezgyn Hawk
        Continue()
END

IF
    Global("rqGDGoodPathStep6","GLOBAL",1)
    Global("rqGDKrivySpawn","AR7212",0) // Undercellar
THEN
    RESPONSE #100
        SetGlobal("rqGDKrivySpawn","AR7212",1) // Undercellar
        CreateCreature("rqkrivy",[1655.1596],0) // Krivy
        CreateCreature("rqenfist",[1820.1425],0) // Flaming Fist Enforcer
        Continue()
END

