/*
COPY_EXISTING ~ar7208.bcs~ ~override~
    DECOMPILE_AND_PATCH BEGIN
        REFACTOR_TRIGGER EXACT_MATCH ~!Exists("BELTBRD")~ ~\0 Global("rqGDMakeBeltDisappear","GLOBAL",1)~
    END
BUT_ONLY
*/

// Remove BELTBRD spawning constantly. I have need to replace Belt with my own rqbelt and BELTBRD just gets in the way.
COPY_EXISTING ~ar7208.bcs~ ~override~
    DECOMPILE_AND_PATCH BEGIN
        SPRINT textToReplace ~\(!Exists("BELTBRD")\)~
        COUNT_REGEXP_INSTANCES ~%textToReplace%~ num_matches
        PATCH_IF (num_matches > 0) BEGIN
            REPLACE_TEXTUALLY CASE_INSENSITIVE ~%textToReplace%~ ~!Exists("rqbelt") !Exists("rqalvier") Global("rqGDBeltPalaceControl","GLOBAL",1) !Exists("BELTBRD")~
            PATCH_PRINT ~Patching: %num_matches% matches found in %SOURCE_FILESPEC% for REPLACE_TEXTUALLY: %textToReplace%~
        END ELSE BEGIN
            PATCH_WARN ~WARNING: could not find %textToReplace% in %SOURCE_FILESPEC%~
        END
    END
BUT_ONLY
/*
// Remove BELTBRD spawning constantly. I have need to replace Belt with my own rqbelt and BELTBRD just gets in the way.
COPY_EXISTING ~aram00.bcs~ ~override~
    DECOMPILE_AND_PATCH BEGIN
        SPRINT textToReplace ~\(CreateCreature("AMBMAEVR",[515.360],W)\)~
        COUNT_REGEXP_INSTANCES ~%textToReplace%~ num_matches
        PATCH_IF (num_matches > 0) BEGIN
            REPLACE_TEXTUALLY CASE_INSENSITIVE ~%textToReplace%~ ~CreateCreature("rqrenal",[515.360],W)~
            PATCH_PRINT ~Patching: %num_matches% matches found in %SOURCE_FILESPEC% for REPLACE_TEXTUALLY: %textToReplace%~
        END ELSE BEGIN
            PATCH_WARN ~WARNING: could not find %textToReplace% in %SOURCE_FILESPEC%~
        END
    END
BUT_ONLY
*/

COPY_EXISTING ~aram00.bcs~ ~override~
    DECOMPILE_AND_PATCH BEGIN
        SPRINT textToReplace ~ActionOverride("AMBMAEVR",DisplayStringWait("AMBMAEVR",75282))~
        COUNT_REGEXP_INSTANCES ~%textToReplace%~ num_matches
        PATCH_IF (num_matches > 0) BEGIN
            REPLACE_TEXTUALLY CASE_INSENSITIVE ~%textToReplace%~ ~ActionOverride("AMBMAEVR",DisplayStringWait("AMBMAEVR",%Take them all back to Amn. We need to move quickly before Renal shows up.%))~
            PATCH_PRINT ~Patching: %num_matches% matches found in %SOURCE_FILESPEC% for REPLACE_TEXTUALLY: %textToReplace%~
        END ELSE BEGIN
            PATCH_WARN ~WARNING: could not find %textToReplace% in %SOURCE_FILESPEC%~
        END
    END
BUT_ONLY

