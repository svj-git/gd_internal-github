// Rhiviq Insurance
IF
    Global("MeetOldenFriends","GLOBAL",100)
    InParty("rqrhiv")
THEN
    RESPONSE #100
        SetGlobal("rqRhiviqJoined","LOCALS",0)
        LeaveParty()
        ActionOverride("rqrhiv",ForceSpell(Myself,DRYAD_TELEPORT))
        Continue()
END
